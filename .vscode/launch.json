{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Budio Workspace Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tools/budio-workspace-vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/tools/budio-workspace-vscode/dist/**/*.js"
      ],
      "preLaunchTask": "budio-workspace: build"
    }
  ]
}
