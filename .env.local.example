## Copy to .env.local for local development only.
## Never commit real secrets.

## Local-safe default target
EXPO_PUBLIC_SUPABASE_TARGET=local

## Local Supabase (default for daily dev)
EXPO_PUBLIC_SUPABASE_LOCAL_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_LOCAL_PUBLISHABLE_KEY=sb_publishable_local_key_here

## Optional cloud target values (only used if EXPO_PUBLIC_SUPABASE_TARGET=cloud)
EXPO_PUBLIC_SUPABASE_CLOUD_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_CLOUD_PUBLISHABLE_KEY=sb_publishable_your_key_here

EXPO_PUBLIC_APP_ENV=development

## Server-only vars (never in client UI code)
APP_SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here
OPENAI_API_KEY=sk-your-server-only-key-here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

## Optional flags
VERCEL_FLAG_DAY_JOURNAL_SOFT_QUALITY_GUARDS=false
VERCEL_FLAG_DAY_JOURNAL_STRICT_VALIDATION=false
EXPO_PUBLIC_VERCEL_FLAG_DEBUG_FUNCTION_AUTH=0
