{
  "name": "persoonlijke-assistent-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:stop": "./scripts/dev-stop.sh",
    "supabase:local:start": "npx supabase start",
    "supabase:local:stop": "npx supabase stop",
    "supabase:functions:serve": "npx supabase functions serve --env-file .env.local",
    "supabase:functions:restart": "./scripts/supabase-functions-restart.sh",
    "start": "npm run dev",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test:chatgpt-markdown-import": "node scripts/test-chatgpt-markdown-import.mjs",
    "test:reflection-helpers": "node scripts/test-reflection-helpers.mjs",
    "verify:local-chatgpt-import": "./scripts/verify-local-chatgpt-import.sh",
    "verify:local-flow": "./scripts/verify-local-flow.sh",
    "verify:local-audio-flow": "./scripts/verify-local-audio-flow.sh",
    "verify:local-reflection-flow": "./scripts/verify-local-reflection-flow.sh",
    "verify:local-output-quality": "./scripts/verify-local-output-quality.sh",
    "env:pull:vercel": "npx vercel env pull .env.vercel.local",
    "docs:bundle": "node scripts/docs/build-chatgpt-project-context.mjs",
    "docs:bundle:verify": "node scripts/docs/build-chatgpt-project-context.mjs --check"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.101.0",
    "@vercel/analytics": "^2.0.1",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-clipboard": "^55.0.11",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "supabase": "^2.84.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
